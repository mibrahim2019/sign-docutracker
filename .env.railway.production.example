# =============================================================================
# Railway production env for: sign-docutracker-production.up.railway.app
# Set these in Railway: Project → Variables (or use railway variables set).
# =============================================================================

# [[REQUIRED - URLs for your Railway app]]
NEXT_PUBLIC_WEBAPP_URL="https://sign-docutracker-production.up.railway.app"
NEXT_PRIVATE_INTERNAL_WEBAPP_URL="https://sign-docutracker-production.up.railway.app"

# [[REQUIRED - generate once, keep secret]]
# Use: openssl rand -hex 32
NEXTAUTH_SECRET="<generate-with-openssl-rand-hex-32>"
# Use: openssl rand -base64 32
NEXT_PRIVATE_ENCRYPTION_KEY="<generate-with-openssl-rand-base64-32>"
NEXT_PRIVATE_ENCRYPTION_SECONDARY_KEY="<generate-with-openssl-rand-base64-32>"

# [[REQUIRED - your existing DB]]
NEXT_PRIVATE_DATABASE_URL="postgresql://postgres.svyngoimakctbiisrfer:MtnVgWtsxQfDjPec@aws-1-us-east-1.pooler.supabase.com:5432/postgres"
NEXT_PRIVATE_DIRECT_DATABASE_URL="postgresql://postgres:MtnVgWtsxQfDjPec@db.svyngoimakctbiisrfer.supabase.co:5432/postgres"

# [[OPTIONAL - skip email verification for testing]]
# NEXT_PRIVATE_BYPASS_EMAIL_VERIFICATION="true"

# [[OPTIONAL - SMTP when you want real emails]]
# NEXT_PRIVATE_SMTP_TRANSPORT="smtp-auth"
# NEXT_PRIVATE_SMTP_HOST="smtp.example.com"
# NEXT_PRIVATE_SMTP_PORT="587"
# NEXT_PRIVATE_SMTP_USERNAME=""
# NEXT_PRIVATE_SMTP_PASSWORD=""
# NEXT_PRIVATE_SMTP_FROM_NAME="DocuTracker"
# NEXT_PRIVATE_SMTP_FROM_ADDRESS="noreply@yourdomain.com"
# NEXT_PRIVATE_SMTP_SECURE="true"

# [[SERVER - Railway sets PORT automatically; leave empty or omit]]
# PORT=

# [[SIGNING - default]]
NEXT_PRIVATE_SIGNING_TRANSPORT="local"

# [[STORAGE - default database]]
NEXT_PUBLIC_UPLOAD_TRANSPORT="database"
